# Backend AHORA — variables locales
# Copia este archivo a .env y completa los valores

# ---- Base de datos (docker compose) ----
DATABASE_URL=postgresql+asyncpg://ahora:ahora@localhost:5433/ahora

# ---- Google Earth Engine ----
# Ruta absoluta al JSON de service account de GEE.
# Si está vacío, el backend corre en MODO MOCK (devuelve datos sintéticos).
GEE_SERVICE_ACCOUNT_JSON=
# Alternativamente, el email + clave privada base64-encoded:
# GEE_SERVICE_ACCOUNT_EMAIL=
# GEE_PRIVATE_KEY_BASE64=

# ---- Storage local ----
# Carpeta donde se guardan tiles PNG y GeoTIFFs generados.
LOCAL_STORAGE_DIR=./storage
# URL pública desde la que se sirven los tiles (FastAPI los expone en /tiles/).
PUBLIC_TILES_BASE_URL=http://localhost:8000/tiles

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ---- Logging ----
LOG_LEVEL=INFO
